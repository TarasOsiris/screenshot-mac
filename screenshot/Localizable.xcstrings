    "Your unlock is managed by the App Store for this Apple Account.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu desbloqueo está gestionado por el App Store para esta cuenta de Apple."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre déverrouillage est géré par le App Store pour ce compte Apple."
