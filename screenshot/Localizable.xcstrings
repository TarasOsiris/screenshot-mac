    "Color, opacity, rotation (in degrees, editable as text), border radius, outline (color + width), and a clip toggle (clips overflow to the shape)." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Farbe, Deckkraft, Drehung (in Grad, als Text bearbeitbar), Rahmenradius, Umriss (Farbe + Breite) und ein Clip-Schalter (Clips überlaufen in die Form)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Couleur, opacité, rotation (en degrés, modifiable sous forme de texte), rayon de bordure, contour (couleur + largeur) et bascule de clip (les clips débordent sur la forme)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "色、不透明度、回転 (度単位、テキストとして編集可能)、境界線の半径、アウトライン (色 + 幅)、およびクリップの切り替え (形状へのクリップのオーバーフロー)。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "색상, 불투명도, 회전(도 단위, 텍스트로 편집 가능), 테두리 반경, 윤곽선(색상 + 너비) 및 클립 토글(클립이 모양으로 오버플로됨)."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cor, opacidade, rotação (em graus, editável como texto), raio da borda, contorno (cor + largura) e alternância de clipe (os clipes transbordam para a forma)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "颜色、不透明度、旋转（以度为单位，可作为文本编辑）、边框半径、轮廓（颜色 + 宽度）和剪辑切换（剪辑溢出到形状）。"
          }
        }
      }
    },
