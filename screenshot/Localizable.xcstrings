    "Edit on one Mac, continue on another." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Auf einem Mac bearbeiten, auf einem anderen fortfahren."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Modifiez sur un Mac, continuez sur un autre."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1 つの Mac を編集し、別の Mac で続行します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mac 하나를 수정하고 다른 항목을 계속하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Edite em um Mac e continue em outro."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "编辑一个 Mac，然后继续编辑另一个。"
          }
        }
      }
    },
    "Edit the base language and each translated language side by side. Leave a cell empty to use the base language text." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
