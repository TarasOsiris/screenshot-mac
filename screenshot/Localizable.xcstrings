    },
    "**⌘]** / **⌘[** cycle forward / backward through languages." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⌘]** / **⌘[** blättern Sie vorwärts/rückwärts durch die Sprachen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⌘]** / **⌘[** avance/recule dans les langues."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⌘]** / **⌘[** 言語を前方または後方に循環します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⌘]** / **⌘[** 언어를 앞뒤로 순환합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⌘]** / **⌘[** avançar/retroceder nos idiomas."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⌘]** / **⌘[** 在语言之间向前/向后循环。"
          }
        }
      }
    },
    "**⌘+** / **⌘−** zoom in/out, **⌘0** resets to 100%, **F** focuses on the current selection." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⌘+** / **⌘−** hinein-/herauszoomen, **⌘0** wird auf 100 % zurückgesetzt, **F** konzentriert sich auf die aktuelle Auswahl."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⌘+** / **⌘−** zoom avant/arrière, **⌘0** se réinitialise à 100 %, **F** se concentre sur la sélection actuelle."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⌘+** / **⌘−** ズームイン/ズームアウト、**⌘0** は 100% にリセット、**F** は現在の選択範囲に焦点を当てます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⌘+** / **⌘−** 확대/축소, **⌘0**은 100%로 재설정, **F**는 현재 선택 항목에 초점을 맞춥니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⌘+** / **⌘−** aumenta/diminui o zoom, **⌘0** redefine para 100%, **F** foca na seleção atual."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⌘+** / **⌘−** 放大/缩小，**⌘0** 重置为 100%，**F** 聚焦于当前选择。"
          }
        }
      }
    },
    "**⌘+** / **⌘−** zoom in/out, **⌘0** resets to the default zoom, **F** focuses on the current selection." : {

    },
    "**⌘⌥0** jumps back to the base language." : {
