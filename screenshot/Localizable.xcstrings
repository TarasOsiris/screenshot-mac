    "The existing %@ screenshot set for %@ may already have been deleted. After fixing the issue, re-run the upload to refill that set." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der vorhandene %@-Screenshot-Satz für %@ wurde möglicherweise bereits gelöscht. Nachdem Sie das Problem behoben haben, führen Sie den Upload erneut aus, um den Satz wieder aufzufüllen."
          }
