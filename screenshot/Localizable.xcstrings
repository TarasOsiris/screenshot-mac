          "stringUnit" : {
            "state" : "translated",
            "value" : "Standardmäßig gilt der Hintergrund einer Zeile für jede Vorlage in der Zeile."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Par défaut, l'arrière-plan d'une ligne s'applique à chaque modèle de la ligne."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デフォルトでは、行の背景はその行内のすべてのテンプレートに適用されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기본적으로 행의 배경은 행의 모든 템플릿에 적용됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Por padrão, o plano de fundo de uma linha se aplica a todos os modelos da linha."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "默认情况下，行的背景适用于该行中的每个模板。"
          }
        }
      }
    },
    "By default, Screenshot Bro exports every language, every row, and every template at 1× scale." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standardmäßig exportiert Screenshot Bro jede Sprache, jede Zeile und jede Vorlage im 1-fachen Maßstab."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Par défaut, Screenshot Bro exporte chaque langue, chaque ligne et chaque modèle à l'échelle 1×."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デフォルトでは、Screenshot Bro はすべての言語、すべての行、およびすべてのテンプレートを 1 倍のスケールでエクスポートします。"
