          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**[設定] ▸ [購入]** に利用可能なプランがリストされます。 RevenueCat がトランザクションを処理します。"
          }
        },
        "ko" : {
