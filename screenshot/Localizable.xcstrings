          }
        }
      }
    },
    "Are you sure you want to reset \"%@\" using the \"%@\" template? All current rows and shapes will be replaced. This cannot be undone.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Are you sure you want to reset \"%1$@\" using the \"%2$@\" template? All current rows and shapes will be replaced. This cannot be undone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Seguro que quieres restablecer «%1$@» usando la plantilla «%2$@»? Todas las filas y formas actuales se reemplazarán. Esta acción no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Êtes-vous sûr de vouloir réinitialiser \"%1$@\" à l'aide du modèle \"%2$@\" ? Toutes les lignes et formes actuelles seront remplacées. Cela ne peut pas être annulé."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sind Sie sicher, dass Sie „%1$@“ mithilfe der Vorlage „%2$@“ zurücksetzen möchten? Alle aktuellen Zeilen und Formen werden ersetzt. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%2$@」テンプレートを使用して「%1$@」をリセットしてもよろしいですか?現在の行と図形はすべて置き換えられます。これを元に戻すことはできません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%2$@\" 템플릿을 사용하여 \"%1$@\"을(를) 재설정하시겠습니까? 현재 행과 도형이 모두 교체됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja redefinir \"%1$@\" usando o modelo \"%2$@\"? Todas as linhas e formas atuais serão substituídas. Isto não pode ser desfeito."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您确定要使用“%2$@”模板重置“%1$@”吗？当前的所有行和形状都将被替换。此操作无法撤消。"
          }
        }
      }
    },
    "Are you sure you want to reset \"%@\"? All rows and shapes will be removed. This cannot be undone.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Seguro que quieres restablecer «%@»? Se eliminarán todas las filas y formas. Esta acción no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Êtes-vous sûr de vouloir réinitialiser \"%1$@\" ? Toutes les lignes et formes seront supprimées. Cela ne peut pas être annulé."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sind Sie sicher, dass Sie „%1$@“ zurücksetzen möchten? Alle Zeilen und Formen werden entfernt. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%1$@」をリセットしてもよろしいですか?すべての行と図形が削除されます。これを元に戻すことはできません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%1$@\"을(를) 재설정하시겠습니까? 모든 행과 도형이 제거됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja redefinir \"%1$@\"? Todas as linhas e formas serão removidas. Isto não pode ser desfeito."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您确定要重置“%1$@”吗？所有行和形状都将被删除。此操作无法撤消。"
          }
        }
      }
    },
