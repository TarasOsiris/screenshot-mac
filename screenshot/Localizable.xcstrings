    "Upload cancelled. Any set that was already being replaced may be empty in App Store Connect — re-run the upload to refill it." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hochladen abgebrochen. Jeder Satz, der bereits ersetzt wurde, kann in App Store Connect leer sein – führen Sie den Upload erneut aus, um ihn wieder aufzufüllen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Envío cancelado. Cualquier conjunto que ya se estuviese reemplazando puede estar vacío en App Store Connect — vuelve a enviar para rellenarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Téléchargement annulé. Tout ensemble déjà en cours de remplacement peut être vide dans App Store Connect — réexécutez le téléchargement pour le remplir."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アップロードがキャンセルされました。すでに置き換えられていたセットは App Store Connect で空になっている可能性があります。アップロードを再実行して補充してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "업로드가 취소되었습니다. 이미 교체된 세트는 App Store Connect에서 비어 있을 수 있습니다. 다시 채우려면 업로드를 다시 실행하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carregamento cancelado. Qualquer conjunto que já estava sendo substituído pode estar vazio em App Store Connect — execute novamente o upload para reabastecê-lo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "上传已取消。任何已被替换的集合在 App Store Connect 中可能为空 - 重新运行上传以重新填充它。"
          }
        }
      }
    },
