            "value" : "Verwenden Sie das Dropdown-Menü **Formen** im Inspektor, um ein Rechteck, einen Kreis oder einen Stern hinzuzufügen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez la liste déroulante **Formes** dans l'inspecteur pour ajouter un rectangle, un cercle ou une étoile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "インスペクターの **図形** ドロップダウンを使用して、長方形、円、または星を追加します。"
          }
        },
        "ko" : {
