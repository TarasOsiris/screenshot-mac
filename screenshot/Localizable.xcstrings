        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**角度**: 中心を中心に回転するスイープ グラデーション。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**각도**: 중심을 중심으로 회전하는 스윕 그라데이션입니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
