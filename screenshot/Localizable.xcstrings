    "Double-click a text shape to edit inline. Press **Esc** or click outside to commit." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doppelklicken Sie auf eine Textform, um sie inline zu bearbeiten. Drücken Sie **Esc** oder klicken Sie außerhalb, um den Commit durchzuführen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Double-cliquez sur une forme de texte pour la modifier en ligne. Appuyez sur **Esc** ou cliquez à l'extérieur pour valider."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "インライン編集するには、テキスト図形をダブルクリックします。 **Esc** を押すか、外側をクリックしてコミットします。"
