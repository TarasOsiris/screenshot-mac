    "Text auto-grows vertically by default. Drag a side handle to fix the width and let it wrap." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Text wächst standardmäßig automatisch vertikal. Ziehen Sie einen Seitengriff, um die Breite festzulegen, und lassen Sie ihn umlaufen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le texte s'agrandit automatiquement verticalement par défaut. Faites glisser une poignée latérale pour fixer la largeur et laissez-la s'enrouler."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デフォルトでは、テキストは垂直方向に自動的に拡大されます。サイドハンドルをドラッグして幅を固定し、折り返すようにします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "텍스트는 기본적으로 수직으로 자동 증가합니다. 측면 핸들을 드래그하여 너비를 고정하고 감싸도록 합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O texto cresce verticalmente automaticamente por padrão. Arraste uma alça lateral para fixar a largura e deixe-a envolver."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "默认情况下，文本自动垂直增长。拖动侧手柄以固定宽度并使其环绕。"
          }
        }
      }
    },
