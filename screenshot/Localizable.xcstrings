    "The application ID of the app on Google Play, e.g. com.example.myapp." : {

    },
    "The existing %@ screenshot set for %@ may already have been deleted. After fixing the issue, re-run the upload to refill that set." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der vorhandene %@-Screenshot-Satz für %@ wurde möglicherweise bereits gelöscht. Nachdem Sie das Problem behoben haben, führen Sie den Upload erneut aus, um den Satz wieder aufzufüllen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El conjunto de capturas %1$@ para %2$@ puede haber sido eliminado. Tras corregir el problema, vuelve a ejecutar el envío para rellenar ese conjunto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
