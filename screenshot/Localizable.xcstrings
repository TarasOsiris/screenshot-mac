          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La capture d'écran %@ existante définie pour %@ a peut-être déjà été supprimée. Après avoir résolu le problème, réexécutez le téléchargement pour remplir cet ensemble."
