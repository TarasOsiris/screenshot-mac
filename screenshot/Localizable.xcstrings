    "Are you sure you want to delete \"%@\"?": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Seguro que quieres eliminar «%@»?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Êtes-vous sûr de vouloir supprimer \"%1$@\" ?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sind Sie sicher, dass Sie „%1$@“ löschen möchten?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%1$@」を削除してもよろしいですか?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%1$@\"을(를) 삭제하시겠습니까?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja excluir \"%1$@\"?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您确定要删除“%1$@”吗？"
          }
        }
      }
    },
    "Are you sure you want to delete \"%@\"? This cannot be undone.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Seguro que quieres eliminar «%@»? Esta acción no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Êtes-vous sûr de vouloir supprimer \"%1$@\" ? Cela ne peut pas être annulé."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sind Sie sicher, dass Sie „%1$@“ löschen möchten? Dies kann nicht rückgängig gemacht werden."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%1$@」を削除してもよろしいですか?これを元に戻すことはできません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%1$@\"을(를) 삭제하시겠습니까? 이 작업은 취소할 수 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja excluir \"%1$@\"? Isto não pode ser desfeito."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您确定要删除“%1$@”吗？此操作无法撤消。"
          }
        }
      }
    },
    "Are you sure you want to delete this screenshot?": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Seguro que quieres eliminar esta captura?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Êtes-vous sûr de vouloir supprimer cette capture d'écran ?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchten Sie diesen Screenshot wirklich löschen?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このスクリーンショットを削除してもよろしいですか?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 스크린샷을 삭제하시겠습니까?"
          }
        },
        "pt-BR": {
