    "Every version on this app is locked for review or live. Create a new version in App Store Connect, then refresh this wizard." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jede Version dieser App ist zur Überprüfung oder Live-Übertragung gesperrt. Erstellen Sie eine neue Version in App Store Connect und aktualisieren Sie dann diesen Assistenten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todas las versiones de esta app están bloqueadas para revisión o ya publicadas. Crea una nueva versión en App Store Connect y luego actualiza este asistente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque version de cette application est verrouillée pour révision ou en direct. Créez une nouvelle version dans App Store Connect, puis actualisez cet assistant."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このアプリのすべてのバージョンは、レビューまたはライブのためにロックされています。 App Store Connect で新しいバージョンを作成し、このウィザードを更新します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 앱의 모든 버전은 검토 또는 게시를 위해 잠겨 있습니다. App Store Connect에서 새 버전을 생성한 후 이 마법사를 새로 고치세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada versão deste aplicativo está bloqueada para revisão ou ao vivo. Crie uma nova versão em App Store Connect e atualize este assistente."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此应用程序上的每个版本都已锁定以供审核或上线。在 App Store Connect 中创建新版本，然后刷新此向导。"
          }
        }
