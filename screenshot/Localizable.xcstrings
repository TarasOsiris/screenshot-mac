          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SVG은 삭제됩니다. 스크립트 및 이벤트 핸들러는 렌더링 전에 제거됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SVGs são higienizados – scripts e manipuladores de eventos são removidos antes da renderização."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
