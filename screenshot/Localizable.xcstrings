    "To All Screenshots": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "A todas las capturas"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vers toutes les captures d'écran"
          }
