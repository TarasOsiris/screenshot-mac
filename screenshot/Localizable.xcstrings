    "%@ Check that the Issuer ID, Key ID, private key, and API key permissions match the App Store Connect key.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ Comprueba que el Issuer ID, el Key ID, la clave privada y los permisos de la clave de API coinciden con la clave de App Store Connect."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ Vérifiez que les autorisations Issuer ID, Key ID, la clé privée et la clé API correspondent à la clé App Store Connect."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ Überprüfen Sie, ob die Berechtigungen für Issuer ID, Key ID, den privaten Schlüssel und den Schlüssel API mit dem Schlüssel App Store Connect übereinstimmen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ Issuer ID、Key ID、秘密キー、および API キーの権限が App Store Connect キーと一致することを確認します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ Issuer ID, Key ID, 개인 키, API 키 권한이 App Store Connect 키와 일치하는지 확인하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ Verifique se as permissões de Issuer ID, Key ID, chave privada e API correspondem à chave App Store Connect."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 检查 Issuer ID、Key ID、私钥和 API 密钥权限是否与 App Store Connect 密钥匹配。"
          }
        }
      }
    },
    "%@ is not allowed for this app/version.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ no está permitido para esta app/versión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ n'est pas autorisé pour cette application/version."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ ist für diese App/Version nicht zulässig."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ はこのアプリ/バージョンでは許可されていません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@은(는) 이 앱/버전에 허용되지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ não é permitido para este aplicativo/versão."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此应用/版本不允许 %1$@。"
          }
        }
      }
    },
