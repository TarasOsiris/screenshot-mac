    "iCloud container is not available. Make sure you're signed into iCloud." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Container iCloud ist nicht verfügbar. Stellen Sie sicher, dass Sie bei iCloud angemeldet sind."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El contenedor de iCloud no está disponible. Asegúrate de haber iniciado sesión en iCloud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le conteneur iCloud n'est pas disponible. Assurez-vous d'être connecté à iCloud."
