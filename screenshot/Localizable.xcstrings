    "All projects will be copied to iCloud. Initial sync may take time for large projects.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos los proyectos se copiarán a iCloud. La sincronización inicial puede tardar con proyectos grandes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tous les projets seront copiés dans iCloud. La synchronisation initiale peut prendre du temps pour les grands projets."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Projekte werden nach iCloud kopiert. Bei großen Projekten kann die erste Synchronisierung einige Zeit dauern."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてのプロジェクトは iCloud にコピーされます。大規模なプロジェクトの場合、初期同期に時間がかかる場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 프로젝트가 iCloud에 복사됩니다. 대규모 프로젝트의 경우 초기 동기화에 시간이 걸릴 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos os projetos serão copiados para iCloud. A sincronização inicial pode levar algum tempo para projetos grandes."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所有项目都将复制到 iCloud。对于大型项目，初始同步可能需要一些时间。"
          }
        }
      }
    },
