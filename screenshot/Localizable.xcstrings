    "%@ Check that the Issuer ID, Key ID, private key, and API key permissions match the App Store Connect key." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ Überprüfen Sie, ob die Berechtigungen für Issuer ID, Key ID, den privaten Schlüssel und den Schlüssel API mit dem Schlüssel App Store Connect übereinstimmen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ Comprueba que el Issuer ID, el Key ID, la clave privada y los permisos de la clave de API coinciden con la clave de App Store Connect."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ Vérifiez que les autorisations Issuer ID, Key ID, la clé privée et la clé API correspondent à la clé App Store Connect."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ Issuer ID、Key ID、秘密キー、および API キーの権限が App Store Connect キーと一致することを確認します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ Issuer ID, Key ID, 개인 키, API 키 권한이 App Store Connect 키와 일치하는지 확인하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ Verifique se as permissões de Issuer ID, Key ID, chave privada e API correspondem à chave App Store Connect."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 检查 Issuer ID、Key ID、私钥和 API 密钥权限是否与 App Store Connect 密钥匹配。"
          }
        }
      }
    },
