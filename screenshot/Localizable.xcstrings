    "Projects will be kept locally. Other Macs will no longer see updates." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Projekte werden vor Ort gehalten. Andere Macs werden keine Updates mehr sehen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los proyectos se conservarán localmente. Otros Macs ya no verán actualizaciones."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les projets seront conservés localement. Les autres Mac ne verront plus les mises à jour."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プロジェクトはローカルに保存されます。他の Mac には更新が表示されなくなります。"
