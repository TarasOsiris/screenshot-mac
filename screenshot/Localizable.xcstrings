        }
      }
    },
    "**Export folder** — choose or clear the folder Screenshot Bro reuses for **⌘E**." : {

    },
    "**File ▸ New Project…** (⌘N) opens the New Project window." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**Datei ▸ Neues Projekt…** (⌘N) öffnet das Fenster „Neues Projekt“."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
