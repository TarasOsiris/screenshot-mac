          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべての言語のすべての行を PNG または JPEG としてレンダリングし、言語ごとのフォルダーに整理するか、ここから App Store Connect に直接アップロードします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모든 언어의 모든 행을 언어별 폴더로 구성된 PNG 또는 JPEG로 렌더링하거나 여기에서 App Store Connect에 바로 업로드하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
