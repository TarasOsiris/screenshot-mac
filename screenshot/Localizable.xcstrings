          }
        }
      }
    },
    "SVGs render with a configurable color override and scale crisply at any export resolution." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SVGs werden mit einer konfigurierbaren Farbüberschreibung gerendert und bei jeder Exportauflösung gestochen scharf skaliert."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le rendu de SVG avec un remplacement de couleur configurable et une mise à l'échelle nette à n'importe quelle résolution d'exportation."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
