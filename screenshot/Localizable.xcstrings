          }
        }
      }
    },
    "**iCloud sync** — toggle and check status." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**iCloud sync** – umschalten und Status prüfen."
          }
        },
        "fr" : {
