    },
    "Use the desktop Mac or iPad app for the best experience." : {

    },
    "Use the export menu for **Export All Screenshots to Folder…**, row exports, showcase exports, per-language exports, and App Store Connect upload." : {

    },
    "Use the inspector on the right to set the background, default device frame, and screenshot size." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwenden Sie den Inspektor auf der rechten Seite, um den Hintergrund, den Standard-Geräterahmen und die Screenshot-Größe festzulegen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez l'inspecteur sur la droite pour définir l'arrière-plan, le cadre par défaut de l'appareil et la taille de la capture d'écran."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "右側のインスペクターを使用して、背景、デフォルトのデバイス フレーム、スクリーンショットのサイズを設定します。"
          }
        },
        "ko" : {
          "stringUnit" : {
