    "All other languages will be re-anchored to it as translations." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle anderen Sprachen werden als Übersetzungen darauf neu ausgerichtet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todos los demás idiomas se reorientarán a él como traducciones."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toutes les autres langues y seront rattachées en tant que traductions."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "他のすべての言語は翻訳としてこの言語に再設定されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다른 모든 언어는 번역으로서 이 언어를 기준으로 다시 정렬됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todos os outros idiomas serão reancorados a ele como traduções."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有其他语言将以它为基准重新锚定为翻译。"
