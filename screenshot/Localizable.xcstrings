            "value" : "Formen"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Formas"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Formes"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "形状"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모양"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Formas"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "形状"
          }
        }
      }
    },
    "Shapes (text, images, devices, etc.) live on the **row canvas** — the unified area behind all templates in a row. A shape can be positioned to land entirely inside one template, or to span across templates." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Formen (Text, Bilder, Geräte usw.) befinden sich auf der **Zeilenleinwand** – dem einheitlichen Bereich hinter allen Vorlagen in einer Zeile. Eine Form kann so positioniert werden, dass sie vollständig innerhalb einer Vorlage landet oder sich über mehrere Vorlagen erstreckt."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les formes (texte, images, appareils, etc.) se trouvent sur le **canevas de ligne** : la zone unifiée derrière tous les modèles d'une rangée. Une forme peut être positionnée pour atterrir entièrement à l’intérieur d’un modèle ou pour s’étendre sur plusieurs modèles."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "図形 (テキスト、画像、デバイスなど) は、**行キャンバス** (行内のすべてのテンプレートの背後にある統一領域) 上に存在します。シェイプは、1 つのテンプレート内に完全に収まるように配置することも、複数のテンプレートにまたがるように配置することもできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "도형(텍스트, 이미지, 장치 등)은 **행 캔버스**(행의 모든 템플릿 뒤에 있는 통합 영역)에 있습니다. 모양은 하나의 템플릿 내부에 완전히 배치되거나 템플릿 전체에 걸쳐 배치될 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As formas (texto, imagens, dispositivos etc.) ficam na **tela de linha** — a área unificada atrás de todos os modelos em uma linha. Uma forma pode ser posicionada para ficar inteiramente dentro de um modelo ou para abranger modelos."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "形状（文本、图像、设备等）位于**行画布**上——行中所有模板后面的统一区域。形状可以定位为完全落在一个模板内，或跨越模板。"
          }
        }
      }
    },
