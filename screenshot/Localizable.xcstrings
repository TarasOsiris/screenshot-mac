    "Disable this row, choose a display type that App Store Connect accepts for this app, or update the app's device support before retrying.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desactiva esta fila, elige un tipo de pantalla que App Store Connect acepte para esta app o actualiza la compatibilidad de dispositivos antes de reintentar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Désactivez cette ligne, choisissez un type d'affichage accepté par App Store Connect pour cette application ou mettez à jour la prise en charge des appareils de l'application avant de réessayer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktivieren Sie diese Zeile, wählen Sie einen Anzeigetyp aus, den App Store Connect für diese App akzeptiert, oder aktualisieren Sie die Geräteunterstützung der App, bevor Sie es erneut versuchen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この行を無効にするか、App Store Connect がこのアプリに対して受け入れる表示タイプを選択するか、再試行する前にアプリのデバイス サポートを更新してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 행을 비활성화하거나 App Store Connect에서 이 앱에 대해 허용하는 디스플레이 유형을 선택하거나, 다시 시도하기 전에 앱의 기기 지원을 업데이트하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desative esta linha, escolha um tipo de exibição que App Store Connect aceite para este aplicativo ou atualize o suporte do dispositivo do aplicativo antes de tentar novamente."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "禁用此行，选择 App Store Connect 此应用接受的显示类型，或者在重试之前更新应用的设备支持。"
          }
        }
      }
    },
