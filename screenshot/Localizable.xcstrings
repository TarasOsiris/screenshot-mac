      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Falta la clave de API de RevenueCat. Configura REVENUECAT_API_KEY en el entorno de la app o en Info.plist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
