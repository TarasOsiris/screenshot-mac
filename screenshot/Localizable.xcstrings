    "**Settings ▸ Purchase** lists the available plans. RevenueCat handles the transaction." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**Einstellungen ▸ Kaufen** listet die verfügbaren Pläne auf. RevenueCat wickelt die Transaktion ab."
          }
        },
        "fr" : {
          "stringUnit" : {
