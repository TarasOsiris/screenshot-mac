    "Manual rotation via the rotation control on the properties bar rotates the entire shape including frame and screen content." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durch die manuelle Drehung über die Drehsteuerung in der Eigenschaftenleiste wird die gesamte Form einschließlich Rahmen und Bildschirminhalt gedreht."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La rotation manuelle via le contrôle de rotation sur la barre de propriétés fait pivoter la forme entière, y compris le contenu du cadre et de l'écran."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プロパティ バーの回転コントロールを使用して手動で回転すると、フレームや画面のコンテンツを含む形状全体が回転します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "속성 표시줄의 회전 컨트롤을 통한 수동 회전은 프레임과 화면 내용을 포함한 전체 모양을 회전합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A rotação manual através do controle de rotação na barra de propriedades gira toda a forma, incluindo o quadro e o conteúdo da tela."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通过属性栏上的旋转控件进行手动旋转可旋转整个形状，包括框架和屏幕内容。"
          }
        }
      }
    },
