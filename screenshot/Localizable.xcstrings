        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "App Store Connect a renvoyé %1$lld en essayant de %2$@."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "App Store Connect hat beim Versuch, %2$@ zurückzugeben, %1$lld zurückgegeben."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "App Store Connect は %2$@ を試行中に %1$lld を返しました。"
          }
