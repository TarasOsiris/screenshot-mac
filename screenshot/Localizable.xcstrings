    "Devices that support landscape (iPad, MacBook) auto-rotate the frame to match the dropped screenshot's aspect ratio." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geräte, die Querformat unterstützen (iPad, MacBuch), drehen den Rahmen automatisch, um ihn an das Seitenverhältnis des abgelegten Screenshots anzupassen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les appareils prenant en charge le mode paysage (iPad, MacLivre) font pivoter automatiquement le cadre pour qu'il corresponde au rapport hauteur/largeur de la capture d'écran déposée."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "横向きをサポートするデバイス (iPad、MacBook) は、ドロップされたスクリーンショットのアスペクト比に合わせてフレームを自動回転します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "가로 모드(iPad, Mac책)를 지원하는 기기는 드롭된 스크린샷의 화면 비율에 맞게 프레임을 자동 회전합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dispositivos compatíveis com paisagem (iPad, MacLivro) giram automaticamente o quadro para corresponder à proporção da captura de tela descartada."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "支持横向（iPad、MacBook）的设备会自动旋转框架以匹配放置的屏幕截图的宽高比。"
          }
        }
      }
    },
