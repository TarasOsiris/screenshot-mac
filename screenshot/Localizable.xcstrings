    "This version is %@ — screenshots can't be changed. Pick an editable version or create a new one in App Store Connect." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Version ist %@ – Screenshots können nicht geändert werden. Wählen Sie eine bearbeitbare Version aus oder erstellen Sie eine neue in App Store Connect."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta versión está en %@ — las capturas no se pueden cambiar. Elige una versión editable o crea una nueva en App Store Connect."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette version est %@ — les captures d'écran ne peuvent pas être modifiées. Choisissez une version modifiable ou créez-en une nouvelle dans App Store Connect."
          }
        },
        "ja" : {
          "stringUnit" : {
