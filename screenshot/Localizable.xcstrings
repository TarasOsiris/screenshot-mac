        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Screenshot Bro verwandelt rohe Geräte-Screenshots in ausgefeilte, verkaufsfertige Marketingbilder. Fügen Sie einen Screenshot ein, wählen Sie einen Geräterahmen aus, fügen Sie eine Überschrift hinzu und exportieren Sie ihn mit genau der Auflösung, die App Store und Google Play erwarten."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Screenshot Bro transforme les captures d'écran brutes de l'appareil en images marketing soignées et prêtes à être utilisées en magasin. Déposez une capture d'écran, choisissez un cadre d'appareil, ajoutez un titre et exportez exactement à la résolution attendue par App Store et Google Play."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Screenshot Bro は、未加工のデバイスのスクリーンショットを、洗練されたストア対応のマーケティング画像に変換します。スクリーンショットをドロップし、デバイス フレームを選択し、見出しを追加して、App Store と Google Play が期待する解像度と正確にエクスポートします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Screenshot Bro 원시 기기 스크린샷을 매장에 바로 사용할 수 있는 세련된 마케팅 이미지로 변환합니다. 스크린샷을 넣고, 장치 프레임을 선택하고, 헤드라인을 추가하고, App Store 및 Google Play에서 기대하는 해상도로 정확하게 내보냅니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Screenshot Bro transforma capturas de tela brutas do dispositivo em imagens de marketing sofisticadas e prontas para a loja. Insira uma captura de tela, escolha um quadro de dispositivo, adicione um título e exporte exatamente na resolução que App Store e Google Play esperam."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Screenshot Bro 将原始设备屏幕截图转换为精美的、可用于商店的营销图像。放入屏幕截图，选择设备框架，添加标题，然后以 App Store 和 Google Play 期望的分辨率导出。"
          }
        }
      }
    },
