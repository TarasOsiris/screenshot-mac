    "Are you sure you want to reset \"%@\" using the \"%@\" template? All current rows and shapes will be replaced. This cannot be undone." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sind Sie sicher, dass Sie „%@“ mithilfe der Vorlage „%@“ zurücksetzen möchten? Alle aktuellen Zeilen und Formen werden ersetzt. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Are you sure you want to reset \"%1$@\" using the \"%2$@\" template? All current rows and shapes will be replaced. This cannot be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Seguro que quieres restablecer «%1$@» usando la plantilla «%2$@»? Todas las filas y formas actuales se reemplazarán. Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir réinitialiser \"%@\" à l'aide du modèle \"%@\" ? Toutes les lignes et formes actuelles seront remplacées. Cela ne peut pas être annulé."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」テンプレートを使用して「%@」をリセットしてもよろしいですか?現在の行と図形はすべて置き換えられます。これを元に戻すことはできません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" 템플릿을 사용하여 \"%@\"을(를) 재설정하시겠습니까? 현재 행과 도형이 모두 교체됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem certeza de que deseja redefinir \"%@\" usando o modelo \"%@\"? Todas as linhas e formas atuais serão substituídas. Isto não pode ser desfeito."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您确定要使用“%@”模板重置“%@”吗？当前的所有行和形状都将被替换。此操作无法撤消。"
          }
        }
      }
    },
