    },
    "Click a shape to select it. **Shift-click** to add to or remove from the selection." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klicken Sie auf eine Form, um sie auszuwählen. **Umschalttaste-Klick**, um etwas zur Auswahl hinzuzufügen oder daraus zu entfernen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cliquez sur une forme pour la sélectionner. **Maj-clic** pour ajouter ou supprimer de la sélection."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "図形をクリックして選択します。 **Shift キーを押しながらクリック**して、選択に追加または選択から削除します。"
          }
        },
        "ko" : {
          "stringUnit" : {
