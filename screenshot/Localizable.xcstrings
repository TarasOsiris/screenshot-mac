          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SVG은 구성 가능한 색상 재정의를 사용하여 렌더링하고 모든 내보내기 해상도에서 선명하게 크기를 조정합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
