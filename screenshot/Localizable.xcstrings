    },
    "App Store Connect did not accept the request. Check the selected app, version, display type, and locale, then retry." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect hat die Anfrage nicht angenommen. Überprüfen Sie die ausgewählte App, die Version, den Anzeigetyp und das Gebietsschema und versuchen Sie es dann erneut."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect no aceptó la solicitud. Comprueba la app, la versión, el tipo de pantalla y el idioma seleccionados y vuelve a intentarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect n'a pas accepté la demande. Vérifiez l'application, la version, le type d'affichage et les paramètres régionaux sélectionnés, puis réessayez."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect はリクエストを受け入れませんでした。選択したアプリ、バージョン、ディスプレイの種類、ロケールを確認して、再試行してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect님이 요청을 수락하지 않았습니다. 선택한 앱, 버전, 디스플레이 유형, 로케일을 확인한 후 다시 시도하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect não aceitou a solicitação. Verifique o aplicativo, a versão, o tipo de exibição e a localidade selecionados e tente novamente."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect 未接受请求。检查所选应用程序、版本、显示类型和区域设置，然后重试。"
          }
        }
      }
    },
    "App Store Connect does not allow %@ (%@) for this app version/localization. This usually means the selected app version does not support that device family, such as uploading iPad screenshots for an iPhone-only app, or App Store Connect does not accept this display type for the selected platform." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect erlaubt %@ (%@) für diese App-Version/Lokalisierung nicht. Dies bedeutet normalerweise, dass die ausgewählte App-Version diese Gerätefamilie nicht unterstützt, z. B. das Hochladen von iPad-Screenshots für eine nur iPhone-App, oder dass App Store Connect diesen Anzeigetyp für die ausgewählte Plattform nicht akzeptiert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect no permite %1$@ (%2$@) para esta versión/idioma. Normalmente significa que la versión seleccionada no admite esa familia de dispositivos, por ejemplo subir capturas de iPad a una app solo para iPhone, o que App Store Connect no acepta este tipo de pantalla para la plataforma elegida."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect n'autorise pas %@ (%@) pour cette version/localisation de cette application. Cela signifie généralement que la version de l'application sélectionnée ne prend pas en charge cette famille d'appareils, par exemple en téléchargeant des captures d'écran de iPad pour une application réservée à iPhone, ou que App Store Connect n'accepte pas ce type d'affichage pour la plate-forme sélectionnée."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect では、このアプリのバージョン/ローカリゼーションに対して %@ (%@) が許可されていません。これは通常、選択したアプリのバージョンがそのデバイス ファミリをサポートしていないこと (iPhone 専用アプリの iPad スクリーンショットのアップロードなど)、または App Store Connect が選択したプラットフォームでこの表示タイプを受け入れないことを意味します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect는 이 앱 버전/현지화에 대해 %@(%@)을 허용하지 않습니다. 이는 일반적으로 선택한 앱 버전이 해당 기기 제품군을 지원하지 않음을 의미합니다. 예를 들어 iPhone 전용 앱에 대한 iPad 스크린샷을 업로드하거나 App Store Connect이(가) 선택한 플랫폼에 대해 이 표시 유형을 허용하지 않습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect não permite %@ (%@) para esta versão/localização do aplicativo. Isso geralmente significa que a versão do aplicativo selecionada não é compatível com essa família de dispositivos, como o upload de capturas de tela de iPad para um aplicativo somente iPhone ou App Store Connect não aceita esse tipo de exibição para a plataforma selecionada."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect 不允许 %@ (%@) 用于此应用版本/本地化。这通常意味着所选应用版本不支持该设备系列，例如上传仅 iPhone 应用的 iPad 屏幕截图，或者 App Store Connect 不接受所选平台的此显示类型。"
          }
        }
      }
    },
    "App Store Connect rejected the request because the API key is not authorized for this app or action. Check that the key has access to this app and enough App Store Connect permissions to edit app metadata." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect hat die Anfrage abgelehnt, da der Schlüssel API für diese App oder Aktion nicht autorisiert ist. Überprüfen Sie, ob der Schlüssel Zugriff auf diese App und über ausreichende App Store Connect-Berechtigungen zum Bearbeiten von App-Metadaten verfügt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect rechazó la solicitud porque la clave de API no está autorizada para esta app o acción. Comprueba que la clave tenga acceso a esta app y permisos suficientes en App Store Connect para editar los metadatos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect a rejeté la demande, car la clé API n'est pas autorisée pour cette application ou cette action. Vérifiez que la clé a accès à cette application et dispose de suffisamment d'autorisations App Store Connect pour modifier les métadonnées de l'application."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "API キーがこのアプリまたはアクションに対して承認されていないため、App Store Connect はリクエストを拒否しました。キーにこのアプリへのアクセス権と、アプリのメタデータを編集するための十分な App Store Connect 権限があることを確認してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect은(는) API 키가 이 앱 또는 작업에 대해 승인되지 않았기 때문에 요청을 거부했습니다. 키에 이 앱에 대한 액세스 권한이 있고 앱 메타데이터를 편집할 수 있는 충분한 App Store Connect 권한이 있는지 확인하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect rejeitou a solicitação porque a chave API não está autorizada para este aplicativo ou ação. Verifique se a chave tem acesso a este aplicativo e permissões App Store Connect suficientes para editar os metadados do aplicativo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect 拒绝了请求，因为 API 密钥未获得此应用或操作的授权。检查该密钥是否有权访问此应用程序以及是否有足够的 App Store Connect 权限来编辑应用程序元数据。"
          }
        }
      }
    },
    "App Store Connect rejects this if the selected app version is iPhone-only." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect lehnt dies ab, wenn die ausgewählte App-Version nur iPhone ist."
          }
        },
        "es" : {
