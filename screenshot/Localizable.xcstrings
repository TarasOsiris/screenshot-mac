    "iCloud container is not available. Make sure you're signed into iCloud.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El contenedor de iCloud no está disponible. Asegúrate de haber iniciado sesión en iCloud."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le conteneur iCloud n'est pas disponible. Assurez-vous d'être connecté à iCloud."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Container iCloud ist nicht verfügbar. Stellen Sie sicher, dass Sie bei iCloud angemeldet sind."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud コンテナは使用できません。 iCloud にサインインしていることを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 컨테이너를 사용할 수 없습니다. iCloud에 로그인했는지 확인하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O contêiner iCloud não está disponível. Certifique-se de estar conectado em iCloud."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 容器不可用。确保您已登录 iCloud。"
          }
        }
      }
    },
    "iCloud is not available. Sign in to iCloud in System Settings.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud no está disponible. Inicia sesión en iCloud en Ajustes del sistema."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud n'est pas disponible. Connectez-vous à iCloud dans System Settings."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud ist nicht verfügbar. Melden Sie sich bei iCloud in System Settings an."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud は利用できません。 System Settings の iCloud にサインインします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud을(를) 사용할 수 없습니다. System Settings에서 iCloud에 로그인합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud não está disponível. Faça login em iCloud em System Settings."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 不可用。在 System Settings 中登录 iCloud。"
          }
        }
      }
    },
