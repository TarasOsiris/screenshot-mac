    "App Store Connect did not accept the request. Check the selected app, version, display type, and locale, then retry." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect no aceptó la solicitud. Comprueba la app, la versión, el tipo de pantalla y el idioma seleccionados y vuelve a intentarlo."
          }
        }
      }
    },
    "App Store Connect does not allow %@ (%@) for this app version/localization. This usually means the selected app version does not support that device family, such as uploading iPad screenshots for an iPhone-only app, or App Store Connect does not accept this display type for the selected platform." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect no permite %1$@ (%2$@) para esta versión/idioma. Normalmente significa que la versión seleccionada no admite esa familia de dispositivos, por ejemplo subir capturas de iPad a una app solo para iPhone, o que App Store Connect no acepta este tipo de pantalla para la plataforma elegida."
          }
        }
      }
    },
    "App Store Connect rejected the request because the API key is not authorized for this app or action. Check that the key has access to this app and enough App Store Connect permissions to edit app metadata." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect rechazó la solicitud porque la clave de API no está autorizada para esta app o acción. Comprueba que la clave tenga acceso a esta app y permisos suficientes en App Store Connect para editar los metadatos."
          }
        }
      }
    },
    "App Store Connect rejects this if the selected app version is iPhone-only." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store Connect lo rechaza si la versión seleccionada es solo para iPhone."
          }
        }
      }
    },
    "App Store Connect returned %lld while trying to %@." : {
      "localizations" : {
        "es" : {
