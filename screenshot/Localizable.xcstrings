        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "인라인으로 편집하려면 텍스트 도형을 두 번 클릭하세요. 커밋하려면 **Esc**를 누르거나 외부를 클릭하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clique duas vezes em uma forma de texto para editá-la in-line. Pressione **Esc** ou clique fora para confirmar."
