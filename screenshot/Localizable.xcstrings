    "**⇧ + Arrow** nudges by 10px." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⇧ + Pfeil** verschiebt sich um 10 Pixel."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⇧ + Flèche** décale de 10 px."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⇧ + 矢印** は 10 ピクセルずつ微調整します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⇧ + 화살표**는 10px씩 이동합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
