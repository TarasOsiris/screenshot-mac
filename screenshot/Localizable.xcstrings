        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3. 장치 프레임을 선택하고, 헤드라인을 추가하고, 배경을 선택하고, 모양을 정렬합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
