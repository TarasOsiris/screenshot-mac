            "value": "Modifiez côte à côte la langue de base et chaque langue traduite. Laissez une cellule vide pour utiliser le texte de la langue de base."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bearbeiten Sie die Basissprache und jede übersetzte Sprache nebeneinander. Lassen Sie eine Zelle leer, um den Text in der Basissprache zu verwenden."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "基本言語と各翻訳言語を並べて編集します。基本言語テキストを使用するには、セルを空のままにしておきます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본 언어와 번역된 각 언어를 나란히 편집합니다. 기본 언어 텍스트를 사용하려면 셀을 비워 두세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Edite o idioma base e cada idioma traduzido lado a lado. Deixe uma célula vazia para usar o texto do idioma base."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "并排编辑基本语言和每种翻译语言。将单元格留空以使用基本语言文本。"
