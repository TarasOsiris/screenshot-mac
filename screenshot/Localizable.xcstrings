    "Values are saved automatically on this Mac. The private key is stored in Keychain.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los valores se guardan automáticamente en este Mac. La clave privada se almacena en el Llavero."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les valeurs sont enregistrées automatiquement sur ce Mac. La clé privée est stockée dans le trousseau."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Werte werden automatisch auf diesem Mac gespeichert. Der private Schlüssel wird im Schlüsselbund gespeichert."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "値はこの Mac に自動的に保存されます。秘密鍵はキーチェーンに保存されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "값은 이 Mac에 자동으로 저장됩니다. 개인 키는 키체인에 저장됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
