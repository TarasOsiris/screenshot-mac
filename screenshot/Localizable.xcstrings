    "When set, Cmd+E exports directly to this folder without prompting.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está establecida, Cmd+E exporta directamente a esta carpeta sin preguntar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsqu'il est défini, Cmd+E exporte directement vers ce dossier sans invite."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn diese Option festgelegt ist, exportiert Cmd+E ohne Aufforderung direkt in diesen Ordner."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定すると、Cmd+E はプロンプトを表示せずにこのフォルダーに直接エクスポートします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정된 경우 Cmd+E는 메시지를 표시하지 않고 이 폴더로 직접 내보냅니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando definido, Cmd+E exporta diretamente para esta pasta sem aviso prévio."
