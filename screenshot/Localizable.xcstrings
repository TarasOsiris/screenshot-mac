    "Projects will be kept locally. Other Macs will no longer see updates.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los proyectos se conservarán localmente. Otros Macs ya no verán actualizaciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les projets seront conservés localement. Les autres Mac ne verront plus les mises à jour."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Projekte werden vor Ort gehalten. Andere Macs werden keine Updates mehr sehen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロジェクトはローカルに保存されます。他の Mac には更新が表示されなくなります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "프로젝트는 로컬에 보관됩니다. 다른 Mac에는 더 이상 업데이트가 표시되지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os projetos serão mantidos localmente. Outros Macs não verão mais atualizações."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "项目将保留在本地。其他Mac将不再看到更新。"
          }
        }
      }
    },
