    "Demo mode is active. Real API key fields above are ignored until you turn demo mode off." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Demomodus ist aktiv. Die obigen echten API-Schlüsselfelder werden ignoriert, bis Sie den Demomodus deaktivieren."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le mode démo est actif. Les véritables champs clés API ci-dessus sont ignorés jusqu'à ce que vous désactiviez le mode démo."
