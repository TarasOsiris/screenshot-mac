    "Purchase completed, but RevenueCat did not grant access. Check the entitlement or product mapping in RevenueCat.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La compra se completó pero RevenueCat no concedió acceso. Revisa la configuración de entitlement o producto en RevenueCat."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Achat terminé, mais RevenueCat n'a pas accordé l'accès. Vérifiez le droit ou le mappage de produit dans RevenueCat."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Kauf wurde abgeschlossen, aber RevenueCat hat keinen Zugriff gewährt. Überprüfen Sie die Berechtigungs- oder Produktzuordnung in RevenueCat."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "購入は完了しましたが、RevenueCat がアクセスを許可しませんでした。 RevenueCat で資格または製品のマッピングを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구매가 완료되었지만 RevenueCat님이 액세스 권한을 부여하지 않았습니다. RevenueCat에서 자격 또는 제품 매핑을 확인하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Compra concluída, mas RevenueCat não concedeu acesso. Verifique o direito ou o mapeamento do produto em RevenueCat."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "购买已完成，但 RevenueCat 未授予访问权限。检查 RevenueCat 中的权利或产品映射。"
          }
        }
      }
    },
