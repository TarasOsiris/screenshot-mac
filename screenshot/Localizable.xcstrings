    "File coordination (`NSFileCoordinator`) prevents corruption from concurrent reads/writes." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Dateikoordination („NSFileCoordinator“) verhindert Beschädigungen durch gleichzeitige Lese-/Schreibvorgänge."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La coordination des fichiers (`NSFileCoordinator`) empêche la corruption due aux lectures/écritures simultanées."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ファイル調整 (`NSFileCoordinator`) は、同時読み取り/書き込みによる破損を防ぎます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "파일 조정(`NSFileCoordinator`)은 동시 읽기/쓰기로 인한 손상을 방지합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A coordenação de arquivos (`NSFileCoordinator`) evita corrupção de leituras/gravações simultâneas."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "文件协调（`NSFileCoordinator`）可防止并发读/写造成的损坏。"
          }
        }
      }
    },
    "File names are zero-padded (`01_…`, `02_…`) so they sort correctly when uploaded." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dateinamen werden mit Nullen aufgefüllt („01_…“, „02_…“), sodass sie beim Hochladen korrekt sortiert werden."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les noms de fichiers sont complétés par des zéros (`01_…`, `02_…`) afin qu'ils soient triés correctement lors du téléchargement."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ファイル名にはゼロが埋め込まれている (`01_…`、`02_…`) ため、アップロード時に正しく並べ替えられます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "파일 이름은 0으로 채워져(`01_…`, `02_…`) 업로드 시 올바르게 정렬됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os nomes dos arquivos são preenchidos com zeros (`01_…`, `02_…`) para que sejam classificados corretamente quando carregados."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "文件名以零填充（`01_...`、`02_...`），以便上传时正确排序。"
          }
        }
      }
    },
