    "Imported fonts are bundled with the project so they survive iCloud sync and project transfer." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Importierte Schriftarten werden mit dem Projekt gebündelt, sodass sie die iCloud Synchronisierung und Projektübertragung überstehen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les polices importées sont regroupées avec le projet afin qu'elles survivent à la synchronisation iCloud et au transfert de projet."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "インポートされたフォントはプロジェクトにバンドルされているため、iCloud の同期やプロジェクトの転送後も存続します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "가져온 글꼴은 프로젝트와 함께 번들로 제공되므로 iCloud 동기화 및 프로젝트 전송이 유지됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As fontes importadas são incluídas no projeto para que sobrevivam à sincronização iCloud e à transferência do projeto."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
