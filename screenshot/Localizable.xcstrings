    "Hold **⇧** while resizing to lock aspect ratio." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Halten Sie **⇧** gedrückt, während Sie die Größe ändern, um das Seitenverhältnis zu sperren."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maintenez **⇧** pendant le redimensionnement pour verrouiller les proportions."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サイズ変更中に**⇧**を押したままにして、アスペクト比をロックします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "가로 세로 비율을 고정하려면 크기를 조정하는 동안 **⇧**를 누르세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segure **⇧** enquanto redimensiona para bloquear a proporção."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "调整大小时按住 **⇧** 可锁定纵横比。"
          }
        }
      }
    },
    "Hold **⌥** while dragging to duplicate the shape as you move." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Halten Sie beim Ziehen **⌥** gedrückt, um die Form beim Verschieben zu duplizieren."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maintenez **⌥** tout en faisant glisser pour dupliquer la forme lorsque vous vous déplacez."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⌥** を押したままドラッグすると、移動に合わせて形状が複製されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**⌥** 키를 누른 채 드래그하면 이동하면서 모양이 복제됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segure **⌥** enquanto arrasta para duplicar a forma conforme você se move."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "拖动时按住 **⌥** 可在移动时复制形状。"
          }
        }
      }
    },
    "Hold the **middle mouse button** and drag to pan." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Halten Sie die **mittlere Maustaste** gedrückt und ziehen Sie zum Schwenken."
